{
  "name": "meowter-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "pnpm --filter kitchensink dev",
    "build": "pnpm -r --filter meowter --filter kitchensink build",
    "build:lib": "pnpm --filter meowter build",
    "build:kitchensink": "pnpm --filter kitchensink build",
    "preview": "pnpm --filter kitchensink preview",
    "test": "pnpm --filter meowter test",
    "typecheck": "pnpm -r typecheck && tsc -p scripts",
    "favicons:gen": "node scripts/generate-favicons.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "engines": {
    "node": ">=26"
  },
  "devDependencies": {
    "@profullstack/favicon-generator": "^1.1.4",
    "@types/node": "^25.0.0"
  }
}
