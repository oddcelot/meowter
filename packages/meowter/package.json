{
  "name": "meowter",
  "version": "0.1.0",
  "description": "Tiny custom-element router built on @solidjs/signals",
  "license": "ISC",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./codegen": {
      "types": "./src/codegen/index.ts",
      "default": "./src/codegen/index.ts"
    },
    "./vite-plugin": {
      "types": "./src/codegen/vite-plugin.ts",
      "default": "./src/codegen/vite-plugin.ts"
    }
  },
  "bin": {
    "meowter-routes": "./src/codegen/cli.ts"
  },
  "files": [
    "dist",
    "src",
    "meowter.html-data.json",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "main": "./dist/meowter.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/meowter.js"
      },
      "./codegen": {
        "types": "./dist/codegen.d.ts",
        "import": "./dist/codegen.js"
      },
      "./vite-plugin": {
        "types": "./dist/vite-plugin.d.ts",
        "import": "./dist/vite-plugin.js"
      }
    },
    "bin": {
      "meowter-routes": "./dist/cli.js"
    }
  },
  "peerDependencies": {
    "@solidjs/signals": "^2.0.0-beta.10"
  },
  "engines": {
    "node": ">=26"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@solidjs/signals": "^2.0.0-beta.10",
    "@types/node": "^25.0.0",
    "happy-dom": "^20.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "node-html-parser": "^7.1.0",
    "tinyglobby": "^0.2.16"
  }
}
