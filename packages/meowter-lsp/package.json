{
  "name": "meowter-lsp",
  "version": "0.1.0",
  "description": "Language server for the meowter router — autocompletes <meow-route> paths in HTML and TS",
  "license": "ISC",
  "type": "module",
  "bin": {
    "meowter-lsp": "./dist/server.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "meowter": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
